# Ollama server base URL.
# Use http://localhost:11434 for local install,
# http://<ip>:11434 for a LAN server (no auth needed),
# or https://<domain> for a Cloudflare Tunnel external server.
OLLAMA_HOST=http://localhost:11434

# Multiple Ollama hosts for parallel translation (comma-separated).
# When set, overrides OLLAMA_HOST. Languages are distributed across all
# hosts that have the required model loaded.
# Example: OLLAMA_HOSTS=http://host1:11434,http://host2:11434
OLLAMA_HOSTS=

# Pin specific languages to specific Ollama hosts (comma-separated LANG=URL pairs).
# Repeat the same language to assign multiple hosts — batches are distributed in parallel.
# Example: OLLAMA_LANG_HOSTS=en=http://host1:11434,fr=http://host2:11434
OLLAMA_LANG_HOSTS=

# Ollama model to use for translation.
# Recommended: qwen2.5:7b (strong Asian/multilingual support)
# Alternative: llama3.1:8b (good for English/European languages)
# Higher quality: qwen2.5:14b (requires 12-16 GB VRAM)
OLLAMA_MODEL=qwen2.5:7b

# Per-language Ollama model overrides (comma-separated LANG=MODEL pairs).
# Each listed language uses its own model instead of OLLAMA_MODEL.
# Hosts that do not have the required model are automatically skipped.
# Example: OLLAMA_LANG_MODELS=zh=qwen2.5:14b,en=llama3.1:8b
OLLAMA_LANG_MODELS=

# Cloudflare Access credentials — REQUIRED only when using an external server
# accessed through a Cloudflare Tunnel with Access Service Auth protection.
# Leave both empty for local or LAN use.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# LM Studio backend (optional — leave all LMS_* variables empty to disable)
# ---------------------------------------------------------------------------

# LM Studio server base URL.
# Use http://localhost:1234 for local install,
# or http://<ip>:1234 for a LAN server.
LMS_HOST=

# Multiple LM Studio hosts for parallel translation (comma-separated).
# When set, overrides LMS_HOST. Ollama and LM Studio hosts can be mixed.
# Example: LMS_HOSTS=http://host1:1234,http://host2:1234
LMS_HOSTS=

# Pin specific languages to specific LM Studio hosts (comma-separated LANG=URL pairs).
# Example: LMS_LANG_HOSTS=en=http://host1:1234,fr=http://host2:1234
LMS_LANG_HOSTS=

# LM Studio model name (as shown in LM Studio's model list).
# Example: qwen2.5-7b-instruct
LMS_MODEL=

# Per-language LM Studio model overrides (comma-separated LANG=MODEL pairs).
# Example: LMS_LANG_MODELS=zh=qwen2.5-7b-instruct,en=meta-llama-3.1-8b-instruct
LMS_LANG_MODELS=

# LM Studio API key for Bearer token authentication.
# Use any non-empty string when LM Studio has no authentication enforced.
# Set to the actual API key when LM Studio is configured with auth required.
LMS_API_KEY=lm-studio

# ---------------------------------------------------------------------------
# Translation settings (shared by all backends)
# ---------------------------------------------------------------------------

# Number of PO entries sent per LLM request.
# Reduce if the model returns errors or truncated responses (try 5 or 10).
TRANSLATE_BATCH_SIZE=20

# LLM request timeout in seconds.
# Increase if using a slow CPU-only server.
TRANSLATE_TIMEOUT=120

# Optional default translation context.
# This text is appended to the system prompt to give the model more context.
# Example: "action RPG video game, dialogue and UI text"
TRANSLATE_CONTEXT=

# Project name for the checkpoint cache directory.
# When set, checkpoints are stored in %TEMP%\po_translator_<NAME> so the cache
# path is predictable and consistent across all team members' machines.
# Leave empty to use an auto-generated hash based on the source folder path.
TRANSLATE_PROJECT=